# Core secrets (never commit real values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://postgres:replace-with-strong-password@db.your-project.supabase.co:5432/postgres

# Internal service wiring
ANOMALY_SERVICE_URL=http://localhost:8001
SUPABASE_SCREENSHOT_BUCKET=earnings

# Runtime security
ENVIRONMENT=development
STRICT_STARTUP=false
JWT_ALGORITHM=HS256

# Optional single frontend URL hint for all services (no trailing slash)
# FRONTEND_URL=https://your-project-name.vercel.app
# VERCEL_FRONTEND_URL=https://your-project-name.vercel.app

# Comma-separated CORS allowlist (no trailing slash)
CORE_ALLOWED_ORIGINS=http://localhost:3000,https://your-project-name.vercel.app
ANOMALY_ALLOWED_ORIGINS=http://localhost:3000,https://your-project-name.vercel.app
CORS_ORIGIN=http://localhost:3000,https://your-project-name.vercel.app
# GRIEVANCE_ALLOWED_ORIGINS=http://localhost:3000,https://your-project-name.vercel.app

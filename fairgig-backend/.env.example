# Core secrets (never commit real values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://postgres:replace-with-strong-password@db.your-project.supabase.co:5432/postgres

# Internal service wiring
ANOMALY_SERVICE_URL=http://localhost:8001

# Runtime security
ENVIRONMENT=development
STRICT_STARTUP=false
JWT_ALGORITHM=HS256

# Comma-separated CORS allowlist (no trailing slash)
CORE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ANOMALY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
